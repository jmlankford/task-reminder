# ── Database ────────────────────────────────────────────────────────────────
# Path inside the container where the SQLite database file is stored.
# The docker-compose volume maps /mnt/user/appdata/taskreminder → /data on the host.
DATABASE_PATH=/data/taskreminder.db

# Timezone used for default active_start_hour and datetime display
TZ=America/New_York


# ── Telegram bot ─────────────────────────────────────────────────────────────
# Token from @BotFather — required for bot to start
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Comma-separated Telegram user IDs allowed to interact with the bot
# Find your ID by messaging @userinfobot on Telegram
TELEGRAM_ALLOWED_IDS=123456789,987654321

# Chat ID that receives proactive HA notifications (usually same as your user ID
# for a personal bot, or a group chat ID for shared use)
TELEGRAM_CHAT_ID=123456789

# ── Home Assistant webhook ───────────────────────────────────────────────────
# Static API key HA sends in the X-API-Key header when calling POST /telegram/notify
TELEGRAM_NOTIFY_API_KEY=change-me-to-a-long-random-string

# Minimum hours between re-notifying about the same reminder (default: 4)
TELEGRAM_NOTIFY_COOLDOWN_HOURS=4

# ── Google Calendar sync ──────────────────────────────────────────────────────
# Path to the service-account JSON key file inside the container
# Share the calendar with the service account's client_email address
GCAL_SERVICE_ACCOUNT_JSON=/data/gcal_service_account.json

# Comma-separated Google Calendar IDs to watch (default: primary)
# Find a calendar's ID in Google Calendar → Settings → <calendar> → Calendar ID
GCAL_CALENDAR_IDS=primary

# How many hours ahead to fetch events (default: 24)
GCAL_LOOKAHEAD_HOURS=24

# Optional static key to protect POST /gcal/sync
# If unset, the endpoint is open (POST only — no GET)
GCAL_API_KEY=change-me-to-a-long-random-string

# ── Receipt printer ───────────────────────────────────────────────────────────
# IP address of the network thermal printer (required to enable receipt printing)
RECEIPT_PRINTER_IP=192.168.1.100

# TCP port for the printer (default: 9100)
RECEIPT_PRINTER_PORT=9100

# Scheduled print times in America/New_York time, 24-hour HH:MM (defaults shown)
RECEIPT_MORNING_TIME=07:30
RECEIPT_EVENING_TIME=19:30

# Custom footer tagline printed at the bottom of every receipt
RECEIPT_FOOTER_TEXT=Task Reminder

# ── Home Assistant integration ────────────────────────────────────────────────
# Shared secret — must match `task_reminder_ha_api_key` in HA's secrets.yaml
HA_API_KEY=change-me-to-a-long-random-string

# Base URL of your Home Assistant instance (no trailing slash)
HA_WEBHOOK_BASE_URL=http://192.168.1.165:8123

# Webhook IDs configured in your HA automations (defaults shown — change only
# if you used different IDs when creating the automations in HA)
HA_LIGHT_ON_WEBHOOK_ID=task-reminder-light-on
HA_LIGHT_OFF_WEBHOOK_ID=task-reminder-light-off
HA_ANNOUNCE_WEBHOOK_ID=task-reminder-announce
